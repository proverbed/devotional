# Copy this file to .env and fill in your Firebase project values.
# Find these in Firebase Console → Project Settings → Your apps → SDK setup.
VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_PROJECT_ID=
VITE_STORAGE_BUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=
VITE_MEASUREMENT_ID=

# Set to "true" to connect to local Firebase Emulator Suite instead of production.
VITE_USE_EMULATOR=false

# Anthropic API key for devotional generation (admin only — keep this secret).
VITE_ANTHROPIC_API_KEY=
